/*
Problem: Right Rotate Array by One Position
Difficulty: Easy

Approach:
1. Store the last element.
2. Shift all elements one position to the right.
3. Place the last element at the beginning.

Time Complexity: O(n)
Space Complexity: O(1)
*/

#include <iostream>
using namespace std;

void rightRotateByOne(int arr[], int n)
{
    if (n <= 1)
        return;

    int last = arr[n - 1];

    for (int i = n - 1; i > 0; i--)
    {
        arr[i] = arr[i - 1];
    }

    arr[0] = last;
}

int main()
{
    int n;

    cout << "Enter size of array: ";
    cin >> n;

    int arr[n];

    cout << "Enter elements:\n";

    for (int i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    rightRotateByOne(arr, n);

    cout << "Array after right rotation:\n";

    for (int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }

    return 0;
}
