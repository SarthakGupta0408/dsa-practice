/*
Problem: Remove Duplicates from Sorted Array
Difficulty: Easy

Approach:
Use two pointers.
One pointer keeps track of unique elements,
while the other traverses the array.

Time Complexity: O(n)
Space Complexity: O(1)
*/

#include <iostream>
using namespace std;

int removeDuplicates(int arr[], int n)
{
    if (n == 0)
        return 0;

    int i = 0;

    for (int j = 1; j < n; j++)
    {
        if (arr[i] != arr[j])
        {
            i++;
            arr[i] = arr[j];
        }
    }

    return i + 1;
}

int main()
{
    int n;

    cout << "Enter size of array: ";
    cin >> n;

    int arr[n];

    cout << "Enter sorted array elements:\n";

    for (int i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    int newSize = removeDuplicates(arr, n);

    cout << "Array after removing duplicates:\n";

    for (int i = 0; i < newSize; i++)
    {
        cout << arr[i] << " ";
    }

    cout << "\nNumber of unique elements: " << newSize;

    return 0;
}
